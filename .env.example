# ─── WorkOS — auth (Part C) ───────────────────────────────────────────────────
# WORKOS_API_KEY=sk_...
# WORKOS_CLIENT_ID=client_...
# WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# ─── Session — encrypted HttpOnly cookie (Part C) ─────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 32
# SESSION_SECRET=

# ─── App URL — used to build invitation links (Part C) ────────────────────────
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Resend — transactional email (Part C invitations) ────────────────────────
# RESEND_API_KEY=re_...
# RESEND_FROM_ADDRESS=noreply@yourdomain.com

# ─── Database — Prisma + PostgreSQL (Part B) ──────────────────────────────────
# Pooled connection (pgBouncer or Supabase pooler) — used by the app at runtime.
# Connect as the superuser/pooler role; forTenant() switches to app_user internally.
# DATABASE_URL=postgresql://<pooler-user>:<password>@<host>:6543/<db>?pgbouncer=true
#
# Direct connection (bypasses pooler) — used by Prisma migrate / seed / service-role.
# DIRECT_URL=postgresql://<pooler-user>:<password>@<host>:5432/<db>
#
# Local dev (embedded-postgres via `pnpm test`): set automatically by tests/setup.ts

# ─── Anthropic — LLM primary provider (Part G) ────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...        ← enterprise endpoint only

# ─── Inngest — background jobs (Part F) ───────────────────────────────────────
# INNGEST_EVENT_KEY=...
# INNGEST_SIGNING_KEY=signkey-...

# ─── Cloudflare R2 — file storage (Part D) ────────────────────────────────────
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=ria-files

# ─── Sentry — error tracking ──────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_AUTH_TOKEN=sntrys_...
# SENTRY_ORG=...
# SENTRY_PROJECT=ria-web

# ─── Langfuse — LLM observability (Part G) ────────────────────────────────────
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASEURL=https://cloud.langfuse.com
